PORT=5000
NODE_ENV=development

# Local MongoDB or MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/parkwise

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Razorpay - leave blank during development/testing; a mock is used automatically.
# Get real test keys from https://dashboard.razorpay.com/app/keys (test mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
